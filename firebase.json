{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "chat-proxy/**",
      "ingest/**",
      "spy/**",
      "**/*.md",
      "**/*.yml",
      "**/*.yaml"
    ],
    "rewrites": [
      { "source": "/api/chat", "function": "chat" }
    ],
    "headers": [
      { "source": "**", "headers": [ { "key": "Cache-Control", "value": "no-cache" } ] }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  }
}
