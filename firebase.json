{
  "hosting": {
    "public": ".",
    "ignore": [
      "**/.*",
      "**/node_modules/**",
      "firebase.json",
      "functions/**",
      "chat-proxy/**",
      "ingest/**",
      "spy/**",
      "skill/**",
      "data/**",
      "docs/**",
      "**/*.md",
      "**/*.yml",
      "**/*.yaml",
      "**/*.json",
      "**/*.sh",
      "**/*.txt",
      "**/*.template"
    ],
    "headers": [
      { "source": "**", "headers": [ { "key": "Cache-Control", "value": "no-cache" } ] }
    ]
  }
}
