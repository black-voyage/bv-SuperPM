{
  "firestore": { "rules": "firestore.rules" },
  "hosting": {
    "public": ".",
    "redirects": [
      { "source": "/dashboard.html", "destination": "/index.html", "type": 301 },
      { "source": "/superpm.html", "destination": "/index.html", "type": 301 }
    ],
    "ignore": [
      "**/.*",
      "**/node_modules/**",
      "firebase.json",
      "functions/**",
      "chat-proxy/**",
      "ingest/**",
      "spy/**",
      "skill/**",
      "data/**",
      "docs/**",
      "**/*.md",
      "**/*.yml",
      "**/*.yaml",
      "**/*.json",
      "**/*.sh",
      "**/*.txt",
      "**/*.template",
      "_preview_*",
      "**/_preview_*"
    ],
    "headers": [
      { "source": "**", "headers": [ { "key": "Cache-Control", "value": "no-cache" } ] }
    ]
  }
}
